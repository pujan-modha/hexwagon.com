# ==========================================
# HexWagon — Environment Variables
# Copy to .env.local and fill in real values
# ==========================================

# ===== Site =====
NEXT_PUBLIC_SITE_URL="http://localhost:5173"
NEXT_PUBLIC_SITE_EMAIL="admin@hexwagon.com"

# ===== Database (Neon) =====
DATABASE_URL="postgresql://user:password@localhost:5432/hexwagon"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/hexwagon"

# ===== Auth (Better Auth) =====
BETTER_AUTH_URL="http://localhost:5173"
BETTER_AUTH_SECRET="your-better-auth-secret-at-least-32-chars"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# ===== Meilisearch =====
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_ADMIN_KEY="your-meilisearch-admin-key"

# ===== Redis (Upstash) =====
REDIS_REST_URL="https://your-redis.upstash.io"
REDIS_REST_TOKEN="your-upstash-redis-token"

# ===== Resend (Email) =====
RESEND_API_KEY="re_your_resend_api_key"
RESEND_SENDER_EMAIL="no-reply@hexwagon.com"

# ===== Amazon S3 =====
S3_ENDPOINT="https://s3.amazonaws.com"
S3_REGION="us-east-1"
S3_BUCKET="your-s3-bucket-name"
S3_ACCESS_KEY="your-aws-access-key"
S3_SECRET_ACCESS_KEY="your-aws-secret-key"
S3_PUBLIC_URL="https://your-cdn-url.com"

# ===== Stripe =====
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# ===== Inngest =====
# Required in production for secure Inngest -> /api/inngest calls
INNGEST_SIGNING_KEY="signkey-prod-..."
# Required only if this app sends events to Inngest API
INNGEST_EVENT_KEY="eventkey-prod-..."

# ===== Analytics (Optional) =====
# PostHog
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_POSTHOG_API_KEY="phc_your_posthog_api_key"
# Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="hexwagon.com"
NEXT_PUBLIC_PLAUSIBLE_URL="https://plausible.io"
PLAUSIBLE_API_KEY="your-plausible-api-key"

# ===== Email Newsletter (Optional) =====
# Beehiiv
BEEHIIV_API_KEY="your-beehiiv-api-key"
BEEHIIV_PUBLICATION_ID="your-beehiiv-publication-id"
