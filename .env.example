# ==========================================
# HexWagon environment template
# Copy to .env.local and replace placeholders
# ==========================================

# ===== Site =====
NEXT_PUBLIC_SITE_URL="http://localhost:5173"
NEXT_PUBLIC_SITE_EMAIL="hello@example.com"

# ===== Database =====
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/YOUR_DB_NAME"
DATABASE_URL_UNPOOLED="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/YOUR_DB_NAME"

# ===== Auth (Better Auth) =====
BETTER_AUTH_URL="http://localhost:5173"
BETTER_AUTH_SECRET="REPLACE_WITH_AT_LEAST_32_CHAR_SECRET"
AUTH_GOOGLE_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
AUTH_GOOGLE_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
AUTH_GITHUB_ID="YOUR_GITHUB_OAUTH_CLIENT_ID"
AUTH_GITHUB_SECRET="YOUR_GITHUB_OAUTH_CLIENT_SECRET"

# ===== Meilisearch =====
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_ADMIN_KEY="YOUR_MEILISEARCH_ADMIN_KEY"

# ===== Redis =====
REDIS_URL="redis://localhost:6379"

# ===== Resend =====
RESEND_API_KEY="YOUR_RESEND_API_KEY"
RESEND_SENDER_EMAIL="no-reply@example.com"

# ===== S3 / Object Storage =====
S3_ENDPOINT="https://s3.example.com"
S3_REGION="YOUR_S3_REGION"
S3_BUCKET="YOUR_S3_BUCKET"
S3_ACCESS_KEY="YOUR_S3_ACCESS_KEY"
S3_SECRET_ACCESS_KEY="YOUR_S3_SECRET_ACCESS_KEY"
S3_PUBLIC_URL="https://cdn.example.com"

# ===== PayPal =====
PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID"
PAYPAL_CLIENT_SECRET="YOUR_PAYPAL_CLIENT_SECRET"
PAYPAL_WEBHOOK_ID="YOUR_PAYPAL_WEBHOOK_ID"
PAYPAL_ENVIRONMENT="sandbox"
PAYPAL_WEEKLY_PLAN_ID="YOUR_PAYPAL_WEEKLY_PLAN_ID"
PAYPAL_MONTHLY_PLAN_ID="YOUR_PAYPAL_MONTHLY_PLAN_ID"

# ===== Inngest =====
INNGEST_SIGNING_KEY="YOUR_INNGEST_SIGNING_KEY"
INNGEST_EVENT_KEY="YOUR_INNGEST_EVENT_KEY"
ENABLE_INDEX_CRON="true"
INDEX_CRON_SCHEDULE="TZ=Europe/Warsaw 0 * * * *"
INDEX_LOOKBACK_MINUTES="90"

# ===== Ops =====
HEALTHCHECK_SECRET="YOUR_HEALTHCHECK_SECRET"

# ===== Analytics =====
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_POSTHOG_API_KEY="YOUR_POSTHOG_API_KEY"
OPENPANEL_API_URL="https://openpanel.example.com/api"
OPENPANEL_CLIENT_ID="YOUR_OPENPANEL_CLIENT_ID"
OPENPANEL_CLIENT_SECRET="YOUR_OPENPANEL_CLIENT_SECRET"
OPENPANEL_PROJECT_ID="YOUR_OPENPANEL_PROJECT_ID"
OPENPANEL_INSIGHTS_BASE_URL="https://openpanel.example.com"

# ===== Beehiiv =====
BEEHIIV_API_KEY="YOUR_BEEHIIV_API_KEY"
BEEHIIV_PUBLICATION_ID="YOUR_BEEHIIV_PUBLICATION_ID"
